{
  "identity": {
    "display_names": ["你的名字"],
    "git_author_names": ["你的 Git 作者名"],
    "git_author_emails": ["you@example.com"],
    "gitlab_usernames": ["你的-gitlab-用户名"],
    "github_usernames": ["你的-github-用户名"],
    "feishu_names": ["你的飞书姓名"],
    "jira_assignees": ["你的-jira-assignee"],
    "linear_assignees": ["你的-linear-assignee"]
  },
  "repositories": {
    "roots": ["."],
    "exclude_dirs": [
      ".git",
      "node_modules",
      ".venv",
      "venv",
      "Library",
      ".Trash",
      "dist",
      "build"
    ],
    "target_branches": ["origin/master", "origin/main", "master", "main"]
  },
  "external_sources": {
    "feishu": [
      {
        "name": "日报/周报工作表",
        "url": "https://example.feishu.cn/wiki/...",
        "identity_field": "assignee",
        "date_field": "date",
        "enabled": false
      }
    ],
    "gitlab": [],
    "github": [],
    "jira": [],
    "linear": []
  },
  "report": {
    "default_template": "leadership_zh",
    "title": "date_only",
    "language": "zh",
    "tone": "leadership",
    "include_evidence_note": "when_relevant",
    "product_prefix_rules": [
      {
        "match": ["Translate", "AiPPT", "ImageEditor", "ChatPDF"],
        "prefix": "Qinyan"
      }
    ]
  },
  "schedule": {
    "daily_enabled": false,
    "daily_local_time": "21:50",
    "weekly_enabled": false,
    "weekly_day": "FR",
    "weekly_local_time": "17:50",
    "timezone": "local",
    "write_evidence": true,
    "write_output": true,
    "auto_send": false
  }
}
